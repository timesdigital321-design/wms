        "count": len(bills)
    })

# ── Excel Import Engine ──────────────────────────────────────────────────────
# Maps messy/real-world spreadsheet headers (like the ones in excel_templates/)
# onto the fields our data stores use, then writes the parsed rows straight
# into inventory.json / transactions.json so Inventory & Stock In/Out reflect
# whatever the user uploads.

def normalize_header(h):
    if h is None:
        return ""
    h = str(h).split("\n")[0].lower()
    h = re.sub(r"[^a-z0-9 ]", " ", h)
    return re.sub(r"\s+", " ", h).strip()

def map_columns(headers, rules):
    """rules: ordered list of (field, [substrings]) — first match wins, each column used once."""
    norm = [normalize_header(h) for h in headers]
    used, out = set(), {}
    for field, patterns in rules:
        for idx, nh in enumerate(norm):
            if idx in used or not nh:
                continue
            if any(p in nh for p in patterns):
                out[field] = idx
                used.add(idx)
                break
    return out

def find_header_row(ws, max_scan=15):
    """Find the row containing an 'SKU' column header; templates bury it under title/instruction rows."""
    scan = min(ws.max_row, max_scan)
    for r in range(1, scan + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        if any(normalize_header(v) == "sku" for v in row_vals):
            return r, row_vals
    for r in range(1, scan + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and str(v).strip() != "" for v in row_vals):
            return r, row_vals
    return 1, []

def parse_number(val, default=0):
    if val is None or str(val).strip() == "":
        return default
    try:
        n = float(val)
        return int(n) if n.is_integer() else n
    except (TypeError, ValueError):
        return default

def parse_text(row, cols, field):
    if field not in cols or cols[field] >= len(row):
        return None
    val = row[cols[field]]
    if val is None or str(val).strip() == "":
        return None
    return str(val).strip()

def parse_date_cell(val):
    if val is None or str(val).strip() == "":
        return None
    if isinstance(val, datetime.datetime):
        return val.date().isoformat()
    if isinstance(val, datetime.date):
        return val.isoformat()
    s = str(val).strip()
    for fmt in ("%d/%m/%Y", "%Y-%m-%d", "%d-%m-%Y", "%m/%d/%Y"):
        try:
            return datetime.datetime.strptime(s, fmt).date().isoformat()
        except ValueError:
            continue
    return None

INVENTORY_RULES = [
    ("sku", ["sku"]),
    ("unit_cost", ["unit cost", "cost"]),
    ("min_level", ["min stock", "min level", "minimum"]),
    ("category", ["category"]),
    ("location", ["location"]),
    ("unit", ["unit"]),
    ("qty", ["quantity", "qty"]),
    ("name", ["item name", "name"]),
]

STOCK_IN_RULES = [
    ("sku", ["sku"]),
    ("unit_cost", ["unit cost"]),
    ("qty", ["quantity received", "quantity", "qty"]),
    ("ref", ["po reference", "po #", "reference", "po"]),
    ("party", ["supplier"]),
    ("unit", ["unit"]),
    ("name", ["item name", "name"]),
    ("date", ["date"]),
    ("notes", ["notes"]),
]

STOCK_OUT_RULES = [
    ("sku", ["sku"]),
    ("qty", ["quantity dispatched", "quantity", "qty"]),
    ("ref", ["delivery order", "do #", "reference"]),
    ("party", ["customer"]),
    ("destination", ["destination", "address"]),
    ("by", ["dispatched by"]),
    ("unit", ["unit"]),
    ("name", ["item name", "name"]),
    ("date", ["date"]),
    ("notes", ["notes"]),
]

def iter_data_rows(ws, header_row):
    for r in range(header_row + 1, ws.max_row + 1):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and str(v).strip() != "" for v in row):
            yield r, row

def import_inventory_excel(path):
    """Inventory uploads are treated as a snapshot: each SKU's qty/details are set to the file's values."""
    wb = openpyxl.load_workbook(path, data_only=True)
    ws = wb.active
    header_row, headers = find_header_row(ws)
    cols = map_columns(headers, INVENTORY_RULES)
    if "sku" not in cols:
        return {"added": 0, "updated": 0, "skipped": 0, "errors": ["Couldn't find a SKU column in this file — check it matches the inventory template."]}

    inv = load_json(INVENTORY_FILE, [])
    by_sku = {i["sku"]: i for i in inv}
    added = updated = skipped = 0
    errors = []

    for r, row in iter_data_rows(ws, header_row):
        sku = (parse_text(row, cols, "sku") or "").upper()
        if not sku:
            skipped += 1
            errors.append(f"Row {r}: missing SKU, skipped")
            continue
        name       = parse_text(row, cols, "name")
        category   = parse_text(row, cols, "category")
        unit       = parse_text(row, cols, "unit")
        location   = parse_text(row, cols, "location")
        qty        = parse_number(row[cols["qty"]]) if "qty" in cols else None
        min_level  = parse_number(row[cols["min_level"]]) if "min_level" in cols else None
        unit_cost  = parse_number(row[cols["unit_cost"]]) if "unit_cost" in cols else None

        if sku in by_sku:
            item = by_sku[sku]
            if name is not None: item["name"] = name
            if category is not None: item["category"] = category
            if qty is not None: item["qty"] = qty
            if unit is not None: item["unit"] = unit
            if min_level is not None: item["min_level"] = min_level
            if location is not None: item["location"] = location
            if unit_cost is not None: item["unit_cost"] = unit_cost
            item["updated"] = today_str()
            updated += 1
        else:
            item = {
                "sku": sku, "name": name or sku, "category": category or "Other",
                "qty": qty or 0, "unit": unit or "PCS", "min_level": min_level or 0,
                "location": location or "", "unit_cost": unit_cost or 0,
                "updated": today_str()
            }
            inv.append(item)
            by_sku[sku] = item
            added += 1

    save_json(INVENTORY_FILE, inv)
    return {"added": added, "updated": updated, "skipped": skipped, "errors": errors}

def import_stock_excel(path, txn_type, username):
    """Stock In/Out uploads create one transaction per row and add/remove qty from inventory."""
    rules = STOCK_IN_RULES if txn_type == "IN" else STOCK_OUT_RULES
    wb = openpyxl.load_workbook(path, data_only=True)
    ws = wb.active
    header_row, headers = find_header_row(ws)
    cols = map_columns(headers, rules)
    if "sku" not in cols or "qty" not in cols:
        return {"processed": 0, "skipped": 0, "errors": ["Couldn't find SKU/Quantity columns in this file — check it matches the stock template."]}

    inv = load_json(INVENTORY_FILE, [])
    by_sku = {i["sku"]: i for i in inv}
    txns = load_json(TRANSACTIONS_FILE, [])
    processed = skipped = 0
    errors = []

    for r, row in iter_data_rows(ws, header_row):
        sku = (parse_text(row, cols, "sku") or "").upper()
        qty = parse_number(row[cols["qty"]], default=0)
        if not sku:
            skipped += 1
            errors.append(f"Row {r}: missing SKU, skipped")
            continue
        if not qty or qty <= 0:
            skipped += 1
            errors.append(f"Row {r} ({sku}): invalid quantity, skipped")
            continue

        name      = parse_text(row, cols, "name")
        unit_cost = parse_number(row[cols["unit_cost"]]) if "unit_cost" in cols else None
        ref       = parse_text(row, cols, "ref") or "BULK-IMPORT"
        party     = parse_text(row, cols, "party") or ""
        notes     = parse_text(row, cols, "notes") or ""
        date_val  = parse_date_cell(row[cols["date"]]) if "date" in cols else None

        item = by_sku.get(sku)
        if not item:
            if txn_type == "OUT":
                skipped += 1
                errors.append(f"Row {r}: SKU {sku} not found in inventory, skipped")
                continue
            item = {
                "sku": sku, "name": name or sku, "category": "Other",
                "qty": 0, "unit": parse_text(row, cols, "unit") or "PCS",
                "min_level": 0, "location": "", "unit_cost": unit_cost or 0,
                "updated": today_str()
            }
            inv.append(item)
            by_sku[sku] = item

        if txn_type == "OUT":
            if item["qty"] < qty:
                skipped += 1
                errors.append(f"Row {r}: insufficient stock for {sku} (have {item['qty']}, need {qty}), skipped")
                continue
            item["qty"] -= qty
        else:
            item["qty"] += qty
            if unit_cost:
                item["unit_cost"] = unit_cost
        item["updated"] = today_str()

        txns.append({
            "id": str(uuid.uuid4()), "datetime": now_str(), "date": date_val or today_str(),
            "type": txn_type, "sku": sku, "name": item["name"], "qty": qty,
            "ref": ref, "party": party, "by": username, "status": "Completed", "notes": notes
        })
        processed += 1

    save_json(INVENTORY_FILE, inv)
    save_json(TRANSACTIONS_FILE, txns)
    return {"processed": processed, "skipped": skipped, "errors": errors}

# ── File Upload ───────────────────────────────────────────────────────────────
ALLOWED_EXTENSIONS = {".xlsx", ".xls"}
MAX_SCAN_BYTES = 20 * 1024 * 1024  # matches MAX_CONTENT_LENGTH

def update_file_status(fid, status, extra=None):
    """Update the status field of a file's metadata entry and persist it."""
    meta = load_json(FILES_META_FILE, [])
    entry = next((m for m in meta if m["id"] == fid), None)
    if entry:
        entry["status"] = status
        entry["status_updated_at"] = now_str()
        if extra:
            entry.update(extra)
        save_json(FILES_META_FILE, meta)
    return entry

def basic_file_scan(path, ext):
    """A lightweight 'virus/integrity scan' stage: checks extension, size, and that
    the file actually opens as a valid workbook (for .xlsx). Returns (ok, reason)."""
    if ext not in ALLOWED_EXTENSIONS:
        return False, "Unsupported file extension"
    size = path.stat().st_size
    if size == 0:
        return False, "File is empty"
    if size > MAX_SCAN_BYTES:
        return False, "File exceeds maximum allowed size"
    if ext == ".xlsx":
        try:
            wb = openpyxl.load_workbook(path, read_only=True)
            wb.close()
        except Exception as e:
            return False, f"File failed integrity check: {e}"
    return True, "OK"

@app.route("/api/files/upload", methods=["POST"])
@require_auth
def upload_file():
    username = request.current_user["username"]

    if "file" not in request.files:
        log_activity(username, "File upload rejected", "Files", "No file provided", status="error")
        return jsonify({"error": "No file provided"}), 400
    f = request.files["file"]
    ext = Path(f.filename).suffix.lower()
    if ext not in ALLOWED_EXTENSIONS:
        log_activity(username, "File upload rejected", "Files",
                      f"{f.filename} — only .xlsx and .xls files allowed", status="error")
        return jsonify({"error": "Only .xlsx and .xls files allowed"}), 400

    file_type = request.form.get("type", "inventory")
    date_str  = request.form.get("date", today_str())
    safe_name = f"{file_type}_{date_str}_{uuid.uuid4().hex[:8]}{ext}"
    save_path = FILES_DIR / safe_name

    # Create the metadata entry up-front so the Files page can show live progress.
    fid = str(uuid.uuid4())
    meta = load_json(FILES_META_FILE, [])
    entry = {
        "id": fid, "filename": safe_name,
        "original_name": f.filename, "type": file_type,
        "date": date_str, "size_kb": 0,
        "uploaded_by": username,
        "uploaded_at": now_str(),
        "status": "uploading",
        "status_updated_at": now_str(),
    }
    meta.append(entry)
    save_json(FILES_META_FILE, meta)
    log_activity(username, "File upload started", "Files",
                 f"{f.filename} ({file_type})", status="info", meta={"file_id": fid})

    # ── Stage 1: Uploading (write bytes to disk) ──────────────────────────────
    try:
        f.save(save_path)
    except Exception as e:
        update_file_status(fid, "error", {"error": f"Could not save file: {e}"})
        log_activity(username, "File upload failed", "Files", f"{f.filename} — {e}", status="error",
                     meta={"file_id": fid})
        return jsonify({"error": f"Could not save file: {e}"}), 500

    size_kb = round(save_path.stat().st_size / 1024, 1)
    update_file_status(fid, "uploaded", {"size_kb": size_kb})
    log_activity(username, "File uploaded", "Files", f"{f.filename} ({size_kb} KB)", status="success",
                 meta={"file_id": fid})

    # ── Stage 2: Scanning (basic integrity / safety checks) ───────────────────
    update_file_status(fid, "scanning")
    log_activity(username, "Scanning file", "Files", f.filename, status="info", meta={"file_id": fid})
    ok, reason = basic_file_scan(save_path, ext)
    if not ok:
        update_file_status(fid, "error", {"error": reason})
        log_activity(username, "File scan failed", "Files", f"{f.filename} — {reason}", status="error",
                     meta={"file_id": fid})
        return jsonify({"id": fid, "filename": safe_name, "status": "error", "error": reason}), 400
    log_activity(username, "File scan passed", "Files", f.filename, status="success", meta={"file_id": fid})

    # ── Stage 3: Processing (parse spreadsheet into inventory/transactions) ───
    update_file_status(fid, "processing")
    log_activity(username, "Processing file", "Files", f"{f.filename} — importing as {file_type}",
                 status="info", meta={"file_id": fid})

    import_result = None
    if ext == ".xlsx":
        try:
            if file_type == "inventory":
                import_result = import_inventory_excel(save_path)
            elif file_type == "stock_in":
                import_result = import_stock_excel(save_path, "IN", username)
            elif file_type == "stock_out":
                import_result = import_stock_excel(save_path, "OUT", username)
        except Exception as e:
            import_result = {"error": f"Could not read this file: {e}"}
    elif file_type in ("inventory", "stock_in", "stock_out"):
        import_result = {"error": "Old .xls format can't be imported automatically — please save as .xlsx and re-upload."}

    if import_result and import_result.get("error"):
        update_file_status(fid, "error", {"error": import_result["error"], "import_result": import_result})
        log_activity(username, "File processing failed", "Files",
                     f"{f.filename} — {import_result['error']}", status="error", meta={"file_id": fid})
    else:
        # ── Stage 4: Done ───────────────────────────────────────────────────
        update_file_status(fid, "done", {"import_result": import_result})
        if import_result:
            if file_type == "inventory":
                summary = f"{import_result.get('added',0)} added, {import_result.get('updated',0)} updated, {import_result.get('skipped',0)} skipped"
            else:
                summary = f"{import_result.get('processed',0)} transactions recorded, {import_result.get('skipped',0)} skipped"
        else:
            summary = "stored (not auto-processed)"
        log_activity(username, "File processing done", "Files", f"{f.filename} — {summary}",
                     status="success", meta={"file_id": fid})

    # Purge old files (retention policy)
    meta = load_json(FILES_META_FILE, [])
    settings = load_json(SETTINGS_FILE, default_settings())
    retention = settings.get("retention_days", 30)
    cutoff = datetime.date.today() - datetime.timedelta(days=retention)
    meta = [m for m in meta if datetime.date.fromisoformat(m["date"]) >= cutoff or not (FILES_DIR / m["filename"]).exists()]
    save_json(FILES_META_FILE, meta)

    final_entry = next((m for m in meta if m["id"] == fid), entry)
    response = dict(final_entry)
    response["import_result"] = import_result
    return jsonify(response), 201

@app.route("/api/files", methods=["GET"])
@require_auth
def list_files():
    meta = load_json(FILES_META_FILE, [])
    t = request.args.get("type","")
    if t:
        meta = [m for m in meta if m["type"] == t]
    return jsonify(meta[::-1])

@app.route("/api/files/<fid>", methods=["DELETE"])
@require_auth
def delete_file(fid):
    meta = load_json(FILES_META_FILE, [])
    entry = next((m for m in meta if m["id"] == fid), None)
    if not entry:
        return jsonify({"error": "File not found"}), 404
    path = FILES_DIR / entry["filename"]
    if path.exists():
        path.unlink()
    meta = [m for m in meta if m["id"] != fid]
    save_json(FILES_META_FILE, meta)
    log_activity(request.current_user["username"], "Deleted file", "Files",
                 entry.get("original_name", entry["filename"]))
    return jsonify({"message": "File deleted"})

@app.route("/api/files/<fid>/download", methods=["GET"])
@require_auth
def download_file(fid):
    meta = load_json(FILES_META_FILE, [])
    entry = next((m for m in meta if m["id"] == fid), None)
    if not entry:
        return jsonify({"error": "File not found"}), 404
    path = FILES_DIR / entry["filename"]
    if not path.exists():
        return jsonify({"error": "File missing from disk"}), 404
    return send_file(path, as_attachment=True, download_name=entry["original_name"])

