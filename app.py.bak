FILES_DIR.mkdir(exist_ok=True)

app = Flask(__name__)
app.config["MAX_CONTENT_LENGTH"] = 20 * 1024 * 1024  # 20 MB

# ── Helpers ──────────────────────────────────────────────────────────────────
def load_json(path, default):
    if Path(path).exists():
        with open(path) as f:
            return json.load(f)
    return default

def save_json(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=2, default=str)

def hash_pw(pw):
    return hashlib.sha256(pw.encode()).hexdigest()

def now_str():
    return datetime.datetime.now().isoformat(timespec="seconds")

def today_str():
    return datetime.date.today().isoformat()

# ── Activity Log ──────────────────────────────────────────────────────────────
# A single, append-only audit trail. Every meaningful action across the app
# (auth, inventory, transactions, billing, users, settings, files) writes one
# entry here. The file-processing pipeline (upload/scan/parse/done) also logs
# its individual stages so the Files page can show real-time-ish status.
MAX_LOG_ENTRIES = 5000

def log_activity(username, action, category, details="", status="success", meta=None):
    """Append one entry to the activity log. Never raises — logging must not break a request."""
    try:
        logs = load_json(LOGS_FILE, [])
        entry = {
            "id": str(uuid.uuid4()),
            "datetime": now_str(),
            "username": username or "system",
            "action": action,
            "category": category,
            "details": details,
            "status": status,
        }
        if meta:
            entry["meta"] = meta
        logs.append(entry)
        if len(logs) > MAX_LOG_ENTRIES:
            logs = logs[-MAX_LOG_ENTRIES:]
        save_json(LOGS_FILE, logs)
        return entry
    except Exception:
        return None

# ── CORS ─────────────────────────────────────────────────────────────────────
@app.after_request
def add_cors(response):
    response.headers["Access-Control-Allow-Origin"] = "*"
    response.headers["Access-Control-Allow-Headers"] = "Content-Type, Authorization"
    response.headers["Access-Control-Allow-Methods"] = "GET, POST, PUT, DELETE, OPTIONS"
    return response

@app.route("/", defaults={"path": ""}, methods=["OPTIONS"])
@app.route("/<path:path>", methods=["OPTIONS"])
def options_handler(path):
    return jsonify({}), 200

