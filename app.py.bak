# ── Config ───────────────────────────────────────────────────────────────────
BASE_DIR   = Path(__file__).parent.parent
DATA_DIR   = BASE_DIR / "data"
FILES_DIR  = BASE_DIR / "uploaded_files"
TEMPL_DIR  = BASE_DIR / "excel_templates"

