# ── Auth ──────────────────────────────────────────────────────────────────────
def require_auth(fn):
    @wraps(fn)
    def wrapped(*args, **kwargs):
        token = request.headers.get("Authorization", "").replace("Bearer ", "")
        sessions = load_json(SESSIONS_FILE, {})
        if token not in sessions:
            return jsonify({"error": "Unauthorized"}), 401
        request.current_user = sessions[token]
        return fn(*args, **kwargs)
    return wrapped

def require_admin(fn):
    @wraps(fn)
    @require_auth
    def wrapped(*args, **kwargs):
        if request.current_user.get("role") != "Admin":
            return jsonify({"error": "Admin access required"}), 403
        return fn(*args, **kwargs)
    return wrapped

@app.route("/api/auth/login", methods=["POST"])
def login():
    data = request.json or {}
    username = data.get("username", "").strip().lower()
    password = data.get("password", "")
    users = load_json(USERS_FILE, [])
    user = next((u for u in users if u["username"].lower() == username), None)
    if not user or user["password"] != hash_pw(password):
        log_activity(username or "unknown", "Login failed", "Auth", "Invalid username or password", status="error")
        return jsonify({"error": "Invalid username or password"}), 401
    if user["status"] != "Active":
        log_activity(username, "Login blocked", "Auth", "Account is inactive", status="error")
        return jsonify({"error": "Account is inactive"}), 403
    # Update last login
    user["last_login"] = now_str()
    save_json(USERS_FILE, users)
    # Create session token
    token = str(uuid.uuid4())
    sessions = load_json(SESSIONS_FILE, {})
    sessions[token] = {
        "user_id": user["id"], "username": user["username"],
        "name": user["name"], "role": user["role"], "access": user["access"]
    }
    save_json(SESSIONS_FILE, sessions)
    log_activity(user["username"], "Logged in", "Auth", f"Role: {user['role']}")
    return jsonify({
        "token": token,
        "user": {"id": user["id"], "name": user["name"],
                 "username": user["username"], "role": user["role"],
                 "access": user["access"]}
    })

@app.route("/api/auth/logout", methods=["POST"])
@require_auth
def logout():
    token = request.headers.get("Authorization", "").replace("Bearer ", "")
    sessions = load_json(SESSIONS_FILE, {})
    sessions.pop(token, None)
    save_json(SESSIONS_FILE, sessions)
    log_activity(request.current_user["username"], "Logged out", "Auth")
    return jsonify({"message": "Logged out"})

@app.route("/api/auth/me", methods=["GET"])
@require_auth
def me():
    return jsonify(request.current_user)

# ── Users ─────────────────────────────────────────────────────────────────────
@app.route("/api/users", methods=["GET"])
@require_admin
def get_users():
    users = load_json(USERS_FILE, [])
    # Strip passwords from response
    safe = [{k: v for k, v in u.items() if k != "password"} for u in users]
    return jsonify(safe)

@app.route("/api/users", methods=["POST"])
@require_admin
def create_user():
    data = request.json or {}
    users = load_json(USERS_FILE, [])
    if any(u["username"].lower() == data.get("username","").lower() for u in users):
        return jsonify({"error": "Username already exists"}), 409
    new_user = {
        "id": str(uuid.uuid4()), "name": data.get("name",""),
        "username": data.get("username","").strip().lower(),
        "password": hash_pw(data.get("password","password123")),
        "role": data.get("role","Staff"),
        "access": data.get("access", ["Dashboard"]),
        "status": "Active", "created": today_str(), "last_login": None
    }
    users.append(new_user)
    save_json(USERS_FILE, users)
    log_activity(request.current_user["username"], "Created user", "Users",
                 f"{new_user['name']} ({new_user['username']}) — role: {new_user['role']}")
    return jsonify({k: v for k, v in new_user.items() if k != "password"}), 201

@app.route("/api/users/<uid>", methods=["PUT"])
@require_admin
def update_user(uid):
    data = request.json or {}
    users = load_json(USERS_FILE, [])
    user = next((u for u in users if u["id"] == uid), None)
    if not user:
        return jsonify({"error": "User not found"}), 404
    for field in ["name", "role", "access", "status"]:
        if field in data:
            user[field] = data[field]
    if "password" in data and data["password"]:
        user["password"] = hash_pw(data["password"])
    save_json(USERS_FILE, users)
    log_activity(request.current_user["username"], "Updated user", "Users",
                 f"{user['name']} ({user['username']})")
    return jsonify({k: v for k, v in user.items() if k != "password"})

@app.route("/api/users/<uid>", methods=["DELETE"])
@require_admin
def delete_user(uid):
    users = load_json(USERS_FILE, [])
    original = len(users)
    target = next((u for u in users if u["id"] == uid), None)
    users = [u for u in users if u["id"] != uid]
    if len(users) == original:
        return jsonify({"error": "User not found"}), 404
    save_json(USERS_FILE, users)
    log_activity(request.current_user["username"], "Deleted user", "Users",
                 f"{target['name']} ({target['username']})" if target else uid)
    return jsonify({"message": "User deleted"})

# ── Inventory ─────────────────────────────────────────────────────────────────
@app.route("/api/inventory", methods=["GET"])
@require_auth
def get_inventory():
    inv = load_json(INVENTORY_FILE, [])
    q = request.args.get("q", "").lower()
    cat = request.args.get("category", "")
    if q:
        inv = [i for i in inv if q in i["name"].lower() or q in i["sku"].lower()]
    if cat:
        inv = [i for i in inv if i["category"] == cat]
    return jsonify(inv)

@app.route("/api/inventory", methods=["POST"])
@require_auth
def add_inventory_item():
    data = request.json or {}
    inv = load_json(INVENTORY_FILE, [])
    if any(i["sku"] == data.get("sku","") for i in inv):
        return jsonify({"error": "SKU already exists"}), 409
    item = {
        "sku": data.get("sku","").upper(),
        "name": data.get("name",""),
        "category": data.get("category",""),
        "qty": int(data.get("qty", 0)),
        "unit": data.get("unit","PCS"),
        "min_level": int(data.get("min_level", 0)),
        "location": data.get("location",""),
        "unit_cost": float(data.get("unit_cost", 0)),
        "updated": today_str()
    }
    inv.append(item)
    save_json(INVENTORY_FILE, inv)
    log_activity(request.current_user["username"], "Added inventory item", "Inventory",
                 f"{item['sku']} — {item['name']} (qty: {item['qty']})")
    return jsonify(item), 201

@app.route("/api/inventory/<sku>", methods=["PUT"])
@require_auth
def update_inventory_item(sku):
    data = request.json or {}
    inv = load_json(INVENTORY_FILE, [])
    item = next((i for i in inv if i["sku"] == sku), None)
    if not item:
        return jsonify({"error": "SKU not found"}), 404
    for field in ["name","category","qty","unit","min_level","location","unit_cost"]:
        if field in data:
            item[field] = data[field]
    item["updated"] = today_str()
    save_json(INVENTORY_FILE, inv)
    log_activity(request.current_user["username"], "Updated inventory item", "Inventory",
                 f"{item['sku']} — {item['name']}")
    return jsonify(item)

@app.route("/api/inventory/<sku>", methods=["DELETE"])
@require_admin
def delete_inventory_item(sku):
    inv = load_json(INVENTORY_FILE, [])
    original = len(inv)
    target = next((i for i in inv if i["sku"] == sku), None)
    inv = [i for i in inv if i["sku"] != sku]
    if len(inv) == original:
        return jsonify({"error": "SKU not found"}), 404
    save_json(INVENTORY_FILE, inv)
    log_activity(request.current_user["username"], "Deleted inventory item", "Inventory",
                 f"{sku}" + (f" — {target['name']}" if target else ""))
    return jsonify({"message": "Item deleted"})

@app.route("/api/inventory/summary", methods=["GET"])
@require_auth
def inventory_summary():
    inv = load_json(INVENTORY_FILE, [])
    low_stock = [i for i in inv if i["qty"] < i["min_level"]]
    total_value = sum(i["qty"] * i.get("unit_cost", 0) for i in inv)
    cats = {}
    for i in inv:
        c = i["category"]
        cats[c] = cats.get(c, 0) + 1
    return jsonify({
        "total_skus": len(inv),
        "total_value": round(total_value, 2),
        "low_stock_count": len(low_stock),
        "low_stock_items": low_stock,
        "by_category": cats
    })

# ── Transactions (Stock In/Out) ────────────────────────────────────────────────
@app.route("/api/transactions", methods=["GET"])
@require_auth
def get_transactions():
    txns = load_json(TRANSACTIONS_FILE, [])
    t = request.args.get("type","")
    if t:
        txns = [tx for tx in txns if tx["type"] == t.upper()]
    limit = int(request.args.get("limit", 100))
    return jsonify(txns[-limit:][::-1])

@app.route("/api/transactions", methods=["POST"])
@require_auth
def add_transaction():
    data = request.json or {}
    txn_type = data.get("type","").upper()
    if txn_type not in ["IN","OUT"]:
        return jsonify({"error": "type must be IN or OUT"}), 400
    sku = data.get("sku","").upper()
    qty = int(data.get("qty", 0))
    if qty <= 0:
        return jsonify({"error": "qty must be > 0"}), 400
    # Update inventory
    inv = load_json(INVENTORY_FILE, [])
    item = next((i for i in inv if i["sku"] == sku), None)
    if not item:
        return jsonify({"error": f"SKU {sku} not found in inventory"}), 404
    if txn_type == "OUT":
        if item["qty"] < qty:
            return jsonify({"error": f"Insufficient stock. Available: {item['qty']}"}), 409
        item["qty"] -= qty
    else:
        item["qty"] += qty
    item["updated"] = today_str()
    save_json(INVENTORY_FILE, inv)
    # Save transaction
    txns = load_json(TRANSACTIONS_FILE, [])
    txn = {
        "id": str(uuid.uuid4()), "datetime": now_str(), "date": data.get("date", today_str()),
        "type": txn_type, "sku": sku, "name": item["name"],
        "qty": qty, "ref": data.get("ref","MANUAL"),
        "party": data.get("party",""), "by": request.current_user["username"],
        "status": "Completed", "notes": data.get("notes","")
    }
    txns.append(txn)
    save_json(TRANSACTIONS_FILE, txns)
    log_activity(request.current_user["username"], f"Stock {txn_type}", "Stock In/Out",
                 f"{sku} — qty {qty}" + (f" — {data.get('party')}" if data.get("party") else ""))
    return jsonify(txn), 201

