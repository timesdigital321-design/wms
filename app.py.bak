@app.route("/api/templates", methods=["GET"])
@require_auth
def list_templates():
    templates = []
    for f in TEMPL_DIR.glob("*.xlsx"):
        templates.append({"filename": f.name, "size_kb": round(f.stat().st_size / 1024, 1)})
    return jsonify(templates)

@app.route("/api/templates/<filename>", methods=["GET"])
@require_auth
def download_template(filename):
    safe = Path(filename).name
    path = TEMPL_DIR / safe
    if not path.exists() or path.suffix != ".xlsx":
        return jsonify({"error": "Template not found"}), 404
    return send_file(path, as_attachment=True, download_name=safe)

# ── Settings ──────────────────────────────────────────────────────────────────
@app.route("/api/settings", methods=["GET"])
@require_auth
def get_settings():
    return jsonify(load_json(SETTINGS_FILE, default_settings()))

@app.route("/api/settings", methods=["PUT"])
@require_admin
def update_settings():
    data = request.json or {}
    settings = load_json(SETTINGS_FILE, default_settings())
    allowed = ["warehouse_name","location","manager","phone","currency","date_format","retention_days","vat_percent"]
    changed = []
    for k in allowed:
        if k in data:
            settings[k] = data[k]
            changed.append(k)
    save_json(SETTINGS_FILE, settings)
    log_activity(request.current_user["username"], "Updated settings", "Settings",
                 f"Changed: {', '.join(changed)}" if changed else "No fields changed")
    return jsonify(settings)

# ── Customers ─────────────────────────────────────────────────────────────────
# A "customer" is anyone goods or invoices went out to: the customer field on a
# bill, or the party field on an OUT stock transaction. There's no separate
# customers.json — customers are derived live from bills + transactions so the
# list never goes stale relative to actual billing/dispatch activity.
def build_customer_index():
    """Returns dict: customer_name -> {bills, stock_outs, total_billed, total_dispatched,
    handled_by: {username: count}, last_activity}."""
    bills = load_json(BILLS_FILE, [])
    txns  = load_json(TRANSACTIONS_FILE, [])
    idx = {}

    def touch(name):
        name = (name or "").strip()
        if not name:
            return None
        if name not in idx:
            idx[name] = {
                "customer": name, "bills": 0, "stock_outs": 0,
                "total_billed": 0.0, "total_dispatched_qty": 0,
                "handled_by": {}, "last_activity": None
            }
        return idx[name]

    for b in bills:
        rec = touch(b.get("customer"))
        if not rec:
            continue
        rec["bills"] += 1
        rec["total_billed"] += float(b.get("amount", 0))
        handler = b.get("created_by", "—")
        rec["handled_by"][handler] = rec["handled_by"].get(handler, 0) + 1
        ts = b.get("created_at") or b.get("date")
        if ts and (rec["last_activity"] is None or ts > rec["last_activity"]):
            rec["last_activity"] = ts

    for t in txns:
        if t.get("type") != "OUT":
            continue
        rec = touch(t.get("party"))
        if not rec:
            continue
        rec["stock_outs"] += 1
        rec["total_dispatched_qty"] += t.get("qty", 0)
        handler = t.get("by", "—")
        rec["handled_by"][handler] = rec["handled_by"].get(handler, 0) + 1
        ts = t.get("datetime")
        if ts and (rec["last_activity"] is None or ts > rec["last_activity"]):
            rec["last_activity"] = ts

    return idx

@app.route("/api/customers", methods=["GET"])
@require_auth
def get_customers():
    """Full customer list, each with totals and a breakdown of which users handled them."""
    idx = build_customer_index()
    customers = sorted(idx.values(), key=lambda c: c["customer"].lower())
    for c in customers:
        c["handled_by"] = [{"username": u, "count": n} for u, n in sorted(c["handled_by"].items(), key=lambda kv: -kv[1])]
    return jsonify(customers)

@app.route("/api/customers/by-user", methods=["GET"])
@require_auth
def get_customers_by_user():
    """Customers grouped by the user who manages/handles them (created the bill or dispatch)."""
    idx = build_customer_index()
    by_user = {}
    for c in idx.values():
        for username in c["handled_by"].keys():
            by_user.setdefault(username, set()).add(c["customer"])
    result = [
        {"username": u, "customer_count": len(names), "customers": sorted(names)}
        for u, names in sorted(by_user.items())
    ]
    return jsonify(result)

# ── Activity Log ──────────────────────────────────────────────────────────────
@app.route("/api/logs", methods=["GET"])
@require_auth
def get_logs():
    """Admins see the full audit trail; Staff/Manager see only their own actions."""
    logs = load_json(LOGS_FILE, [])
    if request.current_user.get("role") != "Admin":
        logs = [l for l in logs if l["username"] == request.current_user["username"]]

    category = request.args.get("category", "")
    username = request.args.get("username", "")
    q        = request.args.get("q", "").lower()
    if category:
        logs = [l for l in logs if l["category"] == category]
    if username:
        logs = [l for l in logs if l["username"] == username]
    if q:
        logs = [l for l in logs if q in l.get("action","").lower() or q in l.get("details","").lower()]

    limit = int(request.args.get("limit", 200))
    logs = logs[::-1][:limit]
    return jsonify(logs)

@app.route("/api/logs/categories", methods=["GET"])
@require_auth
def get_log_categories():
    logs = load_json(LOGS_FILE, [])
    if request.current_user.get("role") != "Admin":
        logs = [l for l in logs if l["username"] == request.current_user["username"]]
    cats = sorted(set(l["category"] for l in logs))
    return jsonify(cats)

# ── Dashboard Summary ─────────────────────────────────────────────────────────
@app.route("/api/dashboard", methods=["GET"])
@require_auth
def dashboard():
    inv     = load_json(INVENTORY_FILE, [])
    txns    = load_json(TRANSACTIONS_FILE, [])
    bills   = load_json(BILLS_FILE, [])
    today   = today_str()
    today_txns = [t for t in txns if t["datetime"].startswith(today)]

    cats = {}
    for i in inv:
        c = i.get("category", "Other")
        cats[c] = cats.get(c, 0) + i.get("qty", 0)
    category_summary = [{"category": c, "total_qty": q} for c, q in sorted(cats.items())]

    customer_idx = build_customer_index()
    customers_sorted = sorted(customer_idx.values(), key=lambda c: c["customer"].lower())
    by_user = {}
    for c in customer_idx.values():
        for username in c["handled_by"].keys():
            by_user.setdefault(username, set()).add(c["customer"])
    customers_by_user = [
        {"username": u, "customer_count": len(names), "customers": sorted(names)}
        for u, names in sorted(by_user.items())
    ]

    return jsonify({
        "stats": {
            "total_items": len(inv),
            "total_value": round(sum(i["qty"] * i.get("unit_cost", 0) for i in inv), 2),
            "stock_in_today": sum(t["qty"] for t in today_txns if t["type"] == "IN"),
            "stock_out_today": sum(t["qty"] for t in today_txns if t["type"] == "OUT"),
            "pending_bills": len([b for b in bills if b["status"] == "Pending"]),
            "pending_value": sum(b["amount"] for b in bills if b["status"] == "Pending"),
            "total_customers": len(customer_idx),
        },
        "low_stock": [i for i in inv if i["qty"] < i["min_level"]],
        "category_summary": category_summary,
        "recent_activity": [
            {**t, "date": t.get("date") or t["datetime"][:10]} for t in txns[-8:][::-1]
        ],
        "customers": customers_sorted,
        "customers_by_user": customers_by_user,
        # legacy/flat fields kept for any other consumers of this endpoint
        "total_skus": len(inv),
        "total_value": round(sum(i["qty"] * i.get("unit_cost",0) for i in inv), 2),
        "low_stock_legacy": [i for i in inv if i["qty"] < i["min_level"]],
        "today_in": sum(t["qty"] for t in today_txns if t["type"]=="IN"),
        "today_out": sum(t["qty"] for t in today_txns if t["type"]=="OUT"),
        "pending_bills": len([b for b in bills if b["status"]=="Pending"]),
        "pending_value": sum(b["amount"] for b in bills if b["status"]=="Pending"),
        "recent_transactions": txns[-8:][::-1]
    })

# ── Reports ───────────────────────────────────────────────────────────────────
@app.route("/api/reports/movement", methods=["GET"])
@require_auth
def movement_report():
    txns = load_json(TRANSACTIONS_FILE, [])
    days = {}
    for t in txns:
        d = t["datetime"][:10]
        days.setdefault(d, {"in": 0, "out": 0})
        if t["type"] == "IN": days[d]["in"] += t["qty"]
        else: days[d]["out"] += t["qty"]
    return jsonify(sorted(days.items()))

